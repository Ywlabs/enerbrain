# 앱
APP_NAME=EnerBrain API
API_V1_PREFIX=/api/v1

# MariaDB 예시 (미설정 시 DB 세션 의존 기능은 사용하지 않음)
# DATABASE_URL=mysql+pymysql://user:password@127.0.0.1:3306/enerbrain?charset=utf8mb4

# CORS — JSON 배열 문자열
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# JWT (PAS 내부 인증)
JWT_SECRET_KEY=CHANGE_ME_PLEASE
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXP_MIN=30
